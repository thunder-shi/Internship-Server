# MySQL
MYSQL_ROOT_PASSWORD=请修改为强密码
MYSQL_DATABASE=internship

# Redis
REDIS_PASSWORD=请修改为强密码

# MinIO（仅容器内使用；与 newback 的 MINIO_ACCESSKEY/SECRET 对应 root）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=请修改为强密码
MINIO_BUCKET=internship

# 入口 HTTP：与 1Panel/OpenResty 共存时改用未占用端口（示例 18088）
HTTP_PUBLISH=18088

# 前端构建：同源带端口访问时一般留空
VITE_KKFILEVIEW_BASE=
